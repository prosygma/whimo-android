<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
<cloud-backup>
    <!-- Include everything in shared_prefs -->
    <include domain="sharedpref" path="." />
    <!-- Exclude auth_prefs.xml (sensitive) -->
    <exclude domain="sharedpref" path="auth_prefs.xml" />
</cloud-backup>

<device-transfer>
    <!-- Include everything in shared_prefs -->
    <include domain="sharedpref" path="." />
    <!-- Exclude auth_prefs.xml (sensitive) -->
    <exclude domain="sharedpref" path="auth_prefs.xml" />
</device-transfer>
</data-extraction-rules>
